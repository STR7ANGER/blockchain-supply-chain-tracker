{
  "name": "blockchain-supply-chain-tracker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @provenance/web",
    "dev:api": "npm run dev --workspace @provenance/api",
    "build": "npm run build --workspaces --if-present",
    "lint": "biome check .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "check": "npm run lint && npm run typecheck && npm test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "proof:test": "cargo test --manifest-path services/proof-registry/Cargo.toml",
    "indexer:test": "cd services/indexer && go test ./...",
    "test:e2e": "playwright test",
    "test:load": "tsx scripts/load-smoke.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "postcss": "^8.5.10",
    "sharp": "^0.35.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.0.0",
    "prisma": "^6.19.3",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "sharp": "^0.35.0",
    "next": {
      "postcss": "^8.5.10",
      "sharp": "^0.35.0"
    }
  }
}
